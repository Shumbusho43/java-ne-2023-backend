# Runtime profile (set to prod in production)
SPRING_PROFILES_ACTIVE=prod

# HTTP
SERVER_PORT=8080
SERVER_HOST=your-api-domain.com

# Security
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=86400000

# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/java2023
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=replace-with-strong-password
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect
SPRING_JPA_OPEN_IN_VIEW=false
